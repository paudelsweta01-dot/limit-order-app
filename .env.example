# Sample environment for the docker-compose stack.
# Copy to `.env` (which is gitignored) and edit secrets.
#
#   cp .env.example .env
#   $EDITOR .env
#
# Compose reads `.env` automatically when running from the repo root.

# --- Postgres ---
# Database, user, and password used by both the postgres service and
# the JDBC URL the backends construct (`SPRING_DATASOURCE_*`). The
# `lob` defaults match `docs/architecture/architecture.md` §7 and the
# backend's Flyway migrations.
POSTGRES_DB=lob
POSTGRES_USER=lob
# CHANGE THIS in `.env`. The example value is a placeholder, not a secret.
POSTGRES_PASSWORD=changeme

# --- JWT signing key ---
# HS256 secret the backend uses to sign + verify JWTs. Must be ≥ 32
# bytes (architecture §4.9). Generate with:
#   openssl rand -base64 48
JWT_SIGNING_SECRET=replace-with-a-32-byte-or-longer-random-string

# --- Outbox retention ---
# How long (in minutes) the janitor keeps fan-out rows in
# `market_event_outbox` before deleting them. 5 is the architecture
# default; bump if you want to inspect historical events post-mortem.
OUTBOX_RETENTION_MINUTES=5
